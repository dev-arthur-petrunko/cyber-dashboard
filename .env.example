# SQLite по умолчанию — ничего менять не нужно для локального запуска
DATABASE_URL=sqlite:///./data/threats.db

# Опционально: для более высоких лимитов NVD API
# Получить бесплатно: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Опционально: поднимает лимит GitHub Search API с 10 до 30 запросов/мин
# Создать: https://github.com/settings/tokens (без прав, только public repo read)
GITHUB_TOKEN=

# Обязательно для ThreatFox и MalwareBazaar (IOC/семплы): abuse.ch требует бесплатный ключ
# Получить: https://auth.abuse.ch/
ABUSECH_AUTH_KEY=

# Опционально: для AlienVault OTX (IoC/pulses)
# Получить: https://otx.alienvault.com/ (профиль → API key)
OTX_API_KEY=
